generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId       String    @id @default(uuid()) @map("user_id")
  email        String    @unique
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  passwordHash String    @map("password_hash")
  phoneNumber  String?   @unique @map("phone_number")
  profileImage String?   @map("profile_image")
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  cartItems     CartItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  orders        WhatsAppOrder[]

  @@index([email])
  @@index([phoneNumber])
  @@index([isActive, isVerified])
  @@map("users")
}

model Admin {
  adminId        String              @id @unique @default(uuid())
  storeSlug      String              @unique @map("store_slug")
  email          String              @unique
  phoneNumber    String?             @unique @map("phone_number")
  firstName      String?             @map("first_name")
  lastName       String?             @map("last_name")
  passwordHash   String              @map("password_hash")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  profileImage   String?             @map("profile_image")
  isActive       Boolean             @default(true)
  products       Product[]
  categories     Category[]
  heroBanners    HeroBanner[]
  whatsAppOrders WhatsAppOrder[]
  notifications  AdminNotification[]

  @@index([email])
  @@index([storeSlug])
  @@map("admins")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String
  description String?  @db.Text
  image       String?
  parentId    Int?     @map("parent_id")
  adminId     String   @map("admin_id")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  admin    Admin      @relation(fields: [adminId], references: [adminId], onDelete: Cascade)
  parent   Category?  @relation("CategoryToParent", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryToParent")

  products    Product[]
  heroBanners HeroBanner[]

  @@unique([slug, adminId])
  @@unique([id, adminId])
  @@index([slug, adminId])
  @@index([parentId, adminId])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id             Int      @id @default(autoincrement())
  adminId        String   @map("admin_id")
  name           String
  slug           String
  description    String?  @db.Text
  categoryId     Int      @map("category_id")
  brand          String?
  isFeatured     Boolean  @default(false) @map("is_featured")
  isActive       Boolean  @default(true) @map("is_active")
  whatsappClicks Int      @default(0) @map("whatsapp_clicks")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  admin    Admin    @relation(fields: [adminId], references: [adminId], onDelete: Cascade)
  category Category @relation(fields: [categoryId, adminId], references: [id, adminId], onDelete: Restrict)

  attributes    ProductAttribute[]
  variants      ProductVariant[]
  reviews       Review[]
  heroBanners   HeroBanner[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orders        WhatsAppOrder[]

  @@unique([slug, adminId])
  @@index([slug, adminId])
  @@index([categoryId, adminId])
  @@index([isActive, sortOrder])
  @@index([createdAt])
  @@map("products")
}

model ProductAttribute {
  id           Int    @id @default(autoincrement())
  productId    Int    @map("product_id")
  key          String
  value        String
  displayOrder Int    @default(0) @map("display_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId])
  @@map("product_attributes")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  productId         Int      @map("product_id")
  displayOrder      Int      @default(0) @map("display_order")
  sku               String?
  price             Decimal  @db.Decimal(10, 2)
  originalPrice     Decimal? @map("original_price") @db.Decimal(10, 2)
  costPrice         Decimal? @map("cost_price") @db.Decimal(10, 2)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")
  optionHash        String   @map("option_hash")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options       VariantOption[]
  images        VariantImage[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orders        WhatsAppOrder[]

  @@unique([productId, optionHash])
  @@unique([sku, productId])
  @@index([productId, optionHash])
  @@index([sku])
  @@index([isActive, stock])
  @@map("product_variants")
}

model VariantOption {
  id        Int            @id @default(autoincrement())
  variantId Int            @map("variant_id")
  key       String
  value     String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, key])
  @@index([key, value])
  @@map("variant_options")
}

model VariantImage {
  id        Int     @id @default(autoincrement())
  variantId Int     @map("variant_id")
  image     String  @map("image")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model HeroBanner {
  id         Int       @id @default(autoincrement())
  productId  Int?      @map("product_id")
  categoryId Int?      @map("category_id")
  adminId    String    @map("admin_id")
  title      String
  subtitle   String?
  image      String
  sortOrder  Int       @default(0) @map("sort_order")
  isActive   Boolean   @default(true) @map("is_active")
  buttonText String?   @map("button_text")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt @map("updated_at")
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")

  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  admin    Admin     @relation(fields: [adminId], references: [adminId], onDelete: Cascade)

  @@index([adminId, isActive, sortOrder])
  @@index([startDate, endDate])
  @@map("hero_banners")
}

model WhatsAppOrder {
  id          Int                 @id @default(autoincrement())
  orderRef    String              @unique
  userId      String?             @map("user_id")
  adminId     String              @map("admin_id")
  productId   Int                 @map("product_id")
  variantId   Int?                @map("variant_id")
  quantity    Int                 @default(1)
  unitPrice   Decimal             @map("unit_price") @db.Decimal(10, 2)
  message     String?             @db.Text
  status      WhatsAppOrderStatus @default(INITIATED)
  createdAt   DateTime            @default(now())
  confirmedAt DateTime?           @map("confirmed_at")
  cancelledAt DateTime?           @map("cancelled_at")
  updatedAt   DateTime            @updatedAt

  // Relations
  user    User?           @relation(fields: [userId], references: [userId], onDelete: SetNull)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  admin   Admin           @relation(fields: [adminId], references: [adminId], onDelete: Cascade)

  @@index([adminId, status])
  @@index([productId, status])
  @@index([createdAt])
  @@map("whatsapp_orders")
}

enum WhatsAppOrderStatus {
  INITIATED // Clicked WhatsApp
  RECEIVED // Seller received message
  PENDING // Awaiting confirmation
  CONFIRMED // Order accepted
  CANCELLED
}

model CartItem {
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  variantId Int      @map("variant_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([userId, productId, variantId])
  @@index([userId])
  @@map("cart_items")
}

model WishlistItem {
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  variantId Int      @map("variant_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([userId, productId, variantId])
  @@index([userId])
  @@map("wishlist_items")
}

model Review {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  productId    Int      @map("product_id")
  rating       Int
  title        String?
  comment      String?  @db.Text
  isVerified   Boolean  @default(false) @map("is_verified")
  isApproved   Boolean  @default(false) @map("is_approved")
  helpfulCount Int      @default(0) @map("helpful_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, isApproved])
  @@index([rating])
  @@map("reviews")
}

enum NotificationType {
  REVIEW_CREATED
  LOW_STOCK
  NEW_ORDER
}

model AdminNotification {
  id        Int              @id @default(autoincrement())
  adminId   String
  type      NotificationType
  entityId  Int? // reviewId
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  admin Admin @relation(fields: [adminId], references: [adminId], onDelete: Cascade)

  @@index([adminId, isRead])
  @@index([adminId, createdAt])
}
